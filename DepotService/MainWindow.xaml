<Window x:Class="DepotService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DepotService"
        mc:Ignorable="d"
        Title="Innomea Depot Paket Manager"
        Height="450"
        Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB" />
        <SolidColorBrush x:Key="BackgroundPrimary" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="BackgroundSecondary" Color="#FFF3F4F6" />
        <SolidColorBrush x:Key="BackgroundTertiary" Color="#FFF9FAFB" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FF111827" />
        <SolidColorBrush x:Key="TextSecondary" Color="#FF6B7280" />
        <SolidColorBrush x:Key="TextTertiary" Color="#FF9CA3AF" />
        <SolidColorBrush x:Key="SuccessColor" Color="#FF059669" />

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderElement"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderElement" Property="Background" Value="#F9FAFB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BorderElement" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="195" />
            <RowDefinition Height="Auto" MinHeight="16" />
            <RowDefinition />
            <RowDefinition Height="Auto" MinHeight="70.04" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0,0,0,1"
                Padding="24,20">
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Depot Counter -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{StaticResource BackgroundTertiary}"
                            CornerRadius="8"
                            Padding="16,8"
                            Margin="0,0,12,0"
                            Height="34">
                        <StackPanel>
                            <TextBlock Text="Depots"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,8,0"
                                       Height="20"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding Depots.Count}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Search Box -->
                <Grid Grid.Row="1" Height="44">
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="40,0,12,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10" />

                    <!-- Search Icon -->
                    <Viewbox Width="18"
                             Height="18"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left"
                             Margin="12,0,0,0"
                             IsHitTestVisible="False"
                             Panel.ZIndex="1">
                        <Canvas Width="24" Height="40">
                            <Path Data="M15.5,14h-0.79l-0.28-0.27 C15.41,12.59,16,11.11,16,9.5 C16,5.91,13.09,3,9.5,3 S3,5.91,3,9.5 S5.91,16,9.5,16 c1.61,0,3.09-0.59,4.23-1.57 l0.27,0.28v0.79l5,4.99L20.49,19 L15.5,14z M9.5,14C7.01,14,5,11.99,5,9.5 S7.01,5,9.5,5S14,7.01,14,9.5 S11.99,14,9.5,14z"
                                  Fill="{StaticResource TextTertiary}"
                                  Stretch="Uniform"
                                  Height="37"
                                  Canvas.Top="-7.681"
                                  Width="53"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Canvas.Left="-6.115"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Grid>
        </Border>

        <!-- Filter and Action Bar -->
        <Border BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0,0,0,1"
                Padding="24,16"
                Background="{StaticResource BackgroundSecondary}"
                Margin="0,114,0,0"
                Height="81"
                VerticalAlignment="Top">
            <Grid Margin="0,0,-15,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" MinWidth="605" />
                </Grid.ColumnDefinitions>

                <!-- Location Filter Section -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,4,60,5">
                    <!-- Filter Toggle Button -->
                    <ToggleButton x:Name="LocationFilterToggle"
                                  IsChecked="{Binding IsFilterPopupOpen, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Padding="6"
                                  ToolTip="Filter">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Path Data="M3,4 L21,4 L13,12 L13,19 L11,21 L11,12 L3,4 Z"
                                      Fill="{StaticResource TextPrimary}"
                                      Stretch="Uniform" />
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>

                    <!-- Filter Popup -->
                    <Popup IsOpen="{Binding IsFilterPopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=LocationFilterToggle}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource BackgroundPrimary}"
                                BorderBrush="{StaticResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Width="300">
                            <StackPanel>
                                <!-- Select All Checkbox -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                    <CheckBox Content="Alle auswählen"
                                              IsThreeState="True"
                                              IsChecked="{Binding AllLocationsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedCount, StringFormat=' ({0} ausgewählt)'}"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Location List -->
                                <TextBlock Text="Standorte" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ScrollViewer Height="180">
                                    <ItemsControl ItemsSource="{Binding Locations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Margin="0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Clear Filter Button -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="Löschen" Command="{Binding ClearFilterCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Selected Location Chips -->
                    <ItemsControl ItemsSource="{Binding SelectedLocations}"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundTertiary}"
                                        CornerRadius="12"
                                        Padding="8,4"
                                        Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <Button Content="✕"
                                                Command="{Binding DataContext.RemoveLocationCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="4"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>


                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Height="37" Margin="168,0,0,0" Width="420">
                    <ComboBox ItemsSource="{Binding JobNames}"
                              SelectedItem="{Binding SelectedJobName, Mode=TwoWay}"
                              Width="180"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              Padding="8,6"
                              BorderBrush="{StaticResource BorderLight}"
                              BorderThickness="1">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                    <Button Content="📦 verteilen"
                            Command="{Binding SyncAllCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,10"
                            Margin="0,0,12,0" />
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,10"
                            Width="99" />
                </StackPanel>
            </Grid>
        </Border>
        <!-- Data Grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DepotsView}"
                  Style="{StaticResource ModernDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DataGridRowStyle}"
                  CellStyle="{StaticResource DataGridCellStyle}"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow">

            <DataGrid.Columns>

                <!-- Checkbox Column -->
                <DataGridTemplateColumn Width="60">
                    <DataGridTemplateColumn.Header>
                        <CheckBox IsThreeState="True"
                                  IsChecked="{Binding SelectAll, Mode=TwoWay}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                

                <!-- Computer with Filter Popup -->
                <DataGridTextColumn Binding="{Binding Computer}" Width="180" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Computer"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center"/>

                                <ToggleButton x:Name="ComputerFilterToggle"
                                              Grid.Column="1"
                                              ToolTip="Computer-Filter"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Margin="8,0,0,0"
                                              Width="26"
                                              Height="26"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding DataContext.IsComputerFilterPopupOpen,
                                                                 RelativeSource={RelativeSource AncestorType={x:Type DataGrid}},
                                                                 Mode=TwoWay}">
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M3,4 L21,4 L13,12 L13,19 L11,21 L11,12 L3,4 Z"
                                                  Fill="{StaticResource TextPrimary}"
                                                  Stretch="Uniform" />
                                        </Canvas>
                                    </Viewbox>
                                </ToggleButton>

                                <Popup IsOpen="{Binding DataContext.IsComputerFilterPopupOpen,
                                                        RelativeSource={RelativeSource AncestorType={x:Type DataGrid}},
                                                        Mode=TwoWay}"
                                       PlacementTarget="{Binding ElementName=ComputerFilterToggle}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{StaticResource BackgroundPrimary}"
                                            BorderBrush="{StaticResource BorderLight}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Width="320">
                                        <StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <CheckBox Content="Alle auswählen"
                                                          IsThreeState="True"
                                                          IsChecked="{Binding DataContext.AllComputersSelected,
                                                                              RelativeSource={RelativeSource AncestorType={x:Type DataGrid}},
                                                                              Mode=TwoWay}" />
                                                <TextBlock Text="{Binding DataContext.SelectedComputerCount,
                                                                          RelativeSource={RelativeSource AncestorType={x:Type DataGrid}},
                                                                          StringFormat=' ({0} ausgewählt)'}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Text="Computer" FontWeight="SemiBold" Margin="0,0,0,8" />

                                            <ScrollViewer Height="220">
                                                <ItemsControl ItemsSource="{Binding DataContext.Computers,
                                                                                    RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="0,4" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                <Button Content="Löschen"
                                                        Command="{Binding DataContext.ClearComputerFilterCommand,
                                                                          RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="12,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Domain -->
                <DataGridTextColumn Header="Domain"
                                    Binding="{Binding Domain}"
                                    Width="140"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Status -->
                <DataGridTemplateColumn Header="Status" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Dein Status-Badge bleibt gleich -->
                            <Border CornerRadius="12"
                                    Padding="10,5"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding JobResult}" Value="Success">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding JobResult}" Value="Completed">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding JobResult}" Value="Error">
                                                <Setter Property="Background" Value="#FEE2E2" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding JobResult}" Value="Pending">
                                                <Setter Property="Background" Value="#FED7AA" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding JobResult}" Value="Running">
                                                <Setter Property="Background" Value="#DBEAFE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding JobResult}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding JobResult}" Value="Success">
                                                        <Setter Property="Foreground" Value="#059669" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding JobResult}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#059669" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding JobResult}" Value="Error">
                                                        <Setter Property="Foreground" Value="#DC2626" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding JobResult}" Value="Pending">
                                                        <Setter Property="Foreground" Value="#EA580C" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding JobResult}" Value="Running">
                                                        <Setter Property="Foreground" Value="#2563EB" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Last Check -->
                <DataGridTextColumn Header="Last Check"
                    Binding="{Binding LastCheck}"
                    Width="120"
                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Information (rechts, füllt Rest) -->
                <DataGridTextColumn Header="Information"
                                    Binding="{Binding Information}"
                                    Width="*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0,1,0,0"
                Padding="24,16"
                Background="{StaticResource BackgroundTertiary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10,0,0,0"
                            Width="630">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <Border Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#EFF6FF"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Lädt..."
                                       Foreground="#3B82F6"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="12,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                                    <Setter Property="Background" Value="#D1FAE5" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Disconnected">
                                    <Setter Property="Background" Value="#FEE2E2" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Unknown">
                                    <Setter Property="Background" Value="#F3F4F6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9CA3AF" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                                            <Setter Property="Fill" Value="#059669" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Disconnected">
                                            <Setter Property="Fill" Value="#DC2626" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Unknown">
                                            <Setter Property="Fill" Value="#9CA3AF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6B7280" />
                                    <Setter Property="Text" Value="Empirum DB " />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                                            <Setter Property="Foreground" Value="#059669" />
                                            <Setter Property="Text" Value="Empirum DB Verbunden" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Disconnected">
                                            <Setter Property="Foreground" Value="#DC2626" />
                                            <Setter Property="Text" Value="Empirum DB Getrennt" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionState}" Value="Unknown">
                                            <Setter Property="Foreground" Value="#6B7280" />
                                            <Setter Property="Text" Value="Empirum DB (unbekannt)" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>